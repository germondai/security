{
  "name": "@germondai/security-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "fix": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "cli": "bun run cli:build && node apps/cli/bin/gsec.mjs",
    "cli:build": "turbo run build --filter=@germondai/security --filter=@germondai/security-cli",
    "cli:gen": "bun run cli -- gen",
    "cli:hash": "bun run cli -- hash",
    "cli:enc": "bun run cli -- enc",
    "cli:dec": "bun run cli -- dec",
    "cli:wizard": "bun run cli -- wizard",
    "web": "bun run web:dev",
    "web:dev": "cd apps/web && bun run dev",
    "web:build": "turbo run build --filter=@germondai/security-web",
    "web:preview": "cd apps/web && bun run preview",
    "core": "turbo run build --filter=@germondai/security",
    "core:test": "bun run --filter @germondai/security test"
  },
  "devDependencies": {
    "turbo": "^2.10.0",
    "typescript": "^6.0.3"
  }
}
