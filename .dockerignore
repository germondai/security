# VCS / IDE
.git
.gitignore
.gitattributes
.github
.gitlab
.idea
.vscode
.DS_Store
Thumbs.db

# Node / Bun artifacts (installed fresh inside the image)
node_modules
**/node_modules
.pnp.*

# Build output (rebuilt inside the image)
**/dist
**/.turbo
**/.vite
**/.tsbuildinfo
**/.cache
**/.next
**/.nuxt
**/.svelte-kit

# Test / coverage
coverage
**/coverage
*.lcov
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx

# Logs / runtime
logs
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*
.npm
.yarn

# Secrets / local env
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Docker (don't recurse)
Dockerfile*
docker-compose*.yml
.dockerignore

# Other apps in the monorepo (apps/cli) — keep in context so bun install --frozen-lockfile
# succeeds; the lockfile records apps/cli as a workspace. Their node_modules / dist are
# excluded above and they are not COPIED into the final image (stage 2 only ships web/dist).
**/bin
