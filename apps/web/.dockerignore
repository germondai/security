# Files excluded from the `docker build` context for `apps/web/`.
# Smaller context = faster builds, less risk of leaking local secrets.

# Vite / TypeScript build artifacts (rebuilt inside the image)
dist
.vite
.turbo
*.tsbuildinfo

# Local dev / tooling
node_modules
coverage
*.log

# Editor / OS noise
.DS_Store
.idea
.vscode
Thumbs.db

# Test artifacts
**/__tests__/**
**/*.test.ts
**/*.spec.ts

# This file itself + sibling scripts that shouldn't ship in the build context
Dockerfile
.dockerignore
server.ts
