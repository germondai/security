# .dockerignore for `docker build -f apps/web/Dockerfile .` (context = apps/web/).
# Keeps the build context small and prevents secret / OS junk from leaking in.

# This file itself and the Dockerfile are excluded by Docker automatically.

# VCS / IDE
**/.git
**/.gitignore
**/.gitattributes
**/.github
**/.gitlab
**/.idea
**/.vscode
**/.DS_Store
**/Thumbs.db

# Node / Bun artifacts (installed fresh inside the image)
**/node_modules
**/node_modules/**
**/.pnp.*
**/bun.lockb

# Build output (rebuilt inside the image)
dist
**/dist
**/dist/**
**/.turbo
**/.vite
**/.tsbuildinfo
**/.cache

# Test / coverage
**/coverage
**/*.lcov
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
**/__tests__
**/__mocks__

# Logs / runtime
**/*.log
**/npm-debug.log
**/yarn-debug.log
**/yarn-error.log
**/bun-debug.log

# Secrets / local env
**/.env
**/.env.*
!**/.env.example
**/.npm
**/.yarn
